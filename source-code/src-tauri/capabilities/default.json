{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$DATA/**" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/**" },
        { "path": "$TEMP/**" },
        { "path": "/var/folders/**" },
        { "path": "/tmp/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-confirm"
  ]
}
