{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArXivLibrary",
  "version": "1.0.0",
  "identifier": "com.pankaj.arxivlibrary",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ArXivLibrary",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Pankaj Sharma",
    "copyright": "© 2026 Pankaj Sharma. MIT licensed. Uses the arXiv API.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "An arXiv-native research library",
    "longDescription": "Search arXiv, organize papers into collections, download and read PDFs, and keep notes. Local-first, cross-platform."
  }
}
